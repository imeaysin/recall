# Database (required)
# Local: pnpm db:up  →  mongodb://localhost:27017/theo
# Atlas free: https://cloud.mongodb.com → Create cluster → Connect → Drivers → copy URI
MONGODB_URI=mongodb://localhost:27017/theo

# Server
PORT=4000
APP_NAME=Theo
NODE_ENV=development

# Auth (required)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32-min-32-chars
BETTER_AUTH_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
# Comma-separated Better Auth user IDs with platform admin access
ADMIN_USER_IDS=

# App URLs (required)
CLIENT_URL=http://localhost:5173
MARKETING_URL=http://localhost:3000

# Web client (Vite) — leave VITE_API_URL/VITE_AUTH_URL empty to use the dev proxy
VITE_API_URL=
VITE_AUTH_URL=
VITE_APP_NAME=Theo
VITE_MARKETING_URL=http://localhost:3000

# Marketing (Next.js) — build-time public URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AUTH_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Theo

# OAuth — product sign-in (need at least one pair)
# Google: https://console.cloud.google.com/apis/credentials
#   Redirect: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
#   Callback: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI — Google Gemini (required for ingestion)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
AI_FLASH_DAILY_REQUEST_CAP=1400
AI_EMBEDDING_DAILY_REQUEST_CAP=1400

# Content ingestion
DAILY_INGESTION_CAP=50
INGESTION_STALE_JOB_MS=300000
INGESTION_MAX_RETRIES=3
CONTENT_TRASH_RETENTION_DAYS=30

# Email (optional — org invites; mock logs to console when empty)
RESEND_API_KEY=
# EMAIL_FROM=Theo <no-reply@yourdomain.com>
# EMAIL_PROVIDER=resend

# Storage (local default; used by /v1/uploads)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_LOCAL_URL=http://localhost:4000/uploads
# STORAGE_SIGNING_SECRET=

# API rate limiting (/v1/*)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Observability (optional — production only; leave blank to disable)
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=api
# VITE_SENTRY_DSN=
