{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Better Auth shared auth package for CogniVault",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./access": {
      "types": "./dist/access/index.d.ts",
      "import": "./dist/access/index.js",
      "require": "./dist/access/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./server/lifecycle": {
      "types": "./dist/server/lifecycle.d.ts",
      "import": "./dist/server/lifecycle.js",
      "require": "./dist/server/lifecycle.cjs"
    },
    "./client": {
      "types": "./dist/client/web.d.ts",
      "import": "./dist/client/web.js",
      "require": "./dist/client/web.cjs"
    },
    "./client/web": {
      "types": "./dist/client/web.d.ts",
      "import": "./dist/client/web.js",
      "require": "./dist/client/web.cjs"
    },
    "./nestjs": {
      "types": "./dist/server/nest/index.d.ts",
      "import": "./dist/server/nest/index.js",
      "require": "./dist/server/nest/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@thallesp/nestjs-better-auth": "^2.7.0",
    "@workspace/config": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/email": "workspace:*",
    "better-auth": "catalog:",
    "mongodb": "^7.2.0",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
